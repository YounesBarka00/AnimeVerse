@{
    Layout = null;
    var title = ViewData["Title"]?.ToString() ?? "AnimeVerse";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>

    <link rel="stylesheet" href="~/css/main.css" />
    <link rel="stylesheet" href="~/css/anime.css" />
    <link rel="stylesheet" href="~/css/details.css" />

    <style>
        body {
            background-color: #0a0a0a;
            color: #fff;
            font-family: "Segoe UI", Arial, sans-serif;
            margin: 0;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #000;
            padding: 20px 40px;
            border-bottom: 2px solid #a4161a;
        }

        .logo {
            font-size: 2rem;
            font-weight: 800;
            background: linear-gradient(90deg, #ffffff, #ff5555);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 12px rgba(255, 85, 85, 0.6);
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            text-decoration: none;
        }

        .header-right {
            display: flex;
            align-items: center;
        }

        .search-bar {
            display: flex;
            gap: 10px;
        }

        .search-input {
            padding: 8px;
            border: 1px solid #a4161a;
            background: #111;
            color: #fff;
            border-radius: 4px;
            width: 220px;
        }

        .search-btn {
            background: #a4161a;
            color: #fff;
            border: none;
            padding: 8px 14px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 600;
        }

        .search-btn:hover {
            background: #ff5555;
        }

        main.content {
            padding: 40px;
        }
    </style>
</head>

<body>

<header>
    <a asp-controller="Anime" asp-action="Index" class="logo">AnimeVerse</a>

    <div class="header-right">
        <form method="get" asp-controller="Anime" asp-action="Index" class="search-bar">
            <input type="search" name="search" class="search-input" placeholder="Search anime..." />
            <button type="submit" class="search-btn">Search</button>
        </form>
    </div>
</header>

<main role="main" class="content">
    @RenderBody()
</main>

</body>
</html>