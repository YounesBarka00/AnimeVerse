@model AnimeVerse.Models.Anime

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    // Set a dynamic page title based on the anime title, with a fallback if the model is null
    ViewData["Title"] = $"{Model?.Title ?? "Anime"} - AnimeVerse";
}

<section class="details-container">

    <div class="details-image">
        <img src="@Model.ImageUrl" alt="@($"{Model.Title} poster")" />
    </div>

    <div class="details-info">

        <div class="details-meta">
            <span class="meta title"><strong>Anime:</strong> @Model.Title</span>

            <span class="meta year">
                <strong>Year:</strong>
                @(Model.Year > 0 ? Model.Year.ToString() : "Unknown")
            </span>

            <span class="meta score">
                <strong>Rating:</strong>
                @(Model.Score > 0 ? Model.Score.ToString("F1") : "Unknown")
            </span>
        </div>

        <div class="synopsis-card">
            <div class="section-title">Synopsis</div>
            
            <!-- Show a default message if the API does not provide a synopsis -->
            <div>
                @(string.IsNullOrWhiteSpace(Model.Synopsis)
                    ? "No description available."
                    : Model.Synopsis)
            </div>
        </div>

        <a href="javascript:history.back()" class="back-link">← Back</a>

    </div>

</section>