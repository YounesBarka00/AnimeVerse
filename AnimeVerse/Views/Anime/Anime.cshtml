@model List<AnimeVerse.Models.Anime>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var searchQuery = Context.Request.Query["search"].ToString();
    
    // Dynamically change the page title depending on whether the user searched or is viewing popular anime
    ViewData["Title"] = string.IsNullOrWhiteSpace(searchQuery)
        ? "Popular Anime"
        : $"Results for \"{searchQuery}\"";
}

<div class="page-header">
    <h1>@ViewData["Title"]</h1>
</div>

@if (!string.IsNullOrEmpty(ViewBag.Message))
{
    <div class="no-results-message">@ViewBag.Message</div>
}

<section class="anime-grid">
    @if (Model != null && Model.Any())
    {
        foreach (var anime in Model)
        {
            <a asp-controller="Anime" asp-action="Details" asp-route-id="@anime.MalId" class="anime-link">

                <div class="anime-card">

                    <img src="@anime.ImageUrl" alt="@($"{anime.Title} poster")" />

                    <div class="anime-info">

                        <h3>@anime.Title</h3>

                        <div class="anime-meta">

                            <!-- Display rating and year, but show fallback values if the API returned missing data -->
                            <span class="meta-rating">
                                @(anime.Score > 0 ? $" {anime.Score:F1}" : " N/A")
                            </span>

                            <span class="meta-year">
                                @(anime.Year > 0 ? anime.Year.ToString() : "Unknown")
                            </span>

                        </div>

                    </div>

                </div>

            </a>
        }
    }
</section>