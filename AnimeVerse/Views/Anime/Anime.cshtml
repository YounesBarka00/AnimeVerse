@model List<AnimeVerse.Models.Anime>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var searchQuery = Context.Request.Query["search"].ToString();
    ViewData["Title"] = string.IsNullOrWhiteSpace(searchQuery) ? "Popular Anime" : $"Search results for \"{searchQuery}\"";
}

<h1>@ViewData["Title"]</h1>

@if (!string.IsNullOrEmpty(ViewBag.Message))
{
    <div class="no-results-message">@ViewBag.Message</div>
}

<section class="anime-grid">
    @if (Model != null && Model.Any())
    {
        foreach (var anime in Model)
        {
            <a asp-controller="Anime" asp-action="Details" asp-route-id="@anime.MalId" class="anime-link">
                <div class="anime-card">
                    <img src="@anime.ImageUrl" alt="@($"{anime.Title} poster")" />

                    <div class="anime-info">
                        <h3>@anime.Title</h3>

                        <p class="score">
                            @(anime.Score > 0 ? $"Rating: {anime.Score:F1}" : "Rating: Unknown")
                        </p>

                        <p class="year">
                            @(anime.Year > 0 ? anime.Year.ToString() : "Unknown year")
                        </p>
                    </div>
                </div>
            </a>
        }
    }
</section>